SQL> CREATE OR REPLACE PROCEDURE Insert_To_Patients(
  2      p_first_name IN VARCHAR2,
  3      p_last_name IN VARCHAR2,
  4      p_dob IN DATE,
  5      p_gender IN VARCHAR2,
  6      p_phone IN VARCHAR2,
  7      p_address IN VARCHAR2
  8  )
  9  AS
 10  BEGIN
 11      INSERT INTO Patients (
 12          patient_id,
 13          first_name,
 14          last_name,
 15          date_of_birth,
 16          gender,
 17          phone_number,
 18          address
 19      ) VALUES (
 20          patient_id_seq.NEXTVAL,
 21          p_first_name,
 22          p_last_name,
 23          p_dob,
 24          p_gender,
 25          p_phone,
 26          p_address
 27      );
 28
 29      COMMIT;
 30      DBMS_OUTPUT.PUT_LINE('Patient record inserted successfully.');
 31  EXCEPTION
 32      WHEN OTHERS THEN
 33          ROLLBACK;
