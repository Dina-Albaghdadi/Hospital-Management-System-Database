SQL> CREATE OR REPLACE PROCEDURE Delete_Patient_Record(
  2     p_patient_id IN NUMBER
  3  )
  4  AS
  5  BEGIN
  6     DELETE FROM Patients
  7     WHERE patient_id = p_patient_id;
  8     IF SQL%ROWCOUNT = 0 THEN
  9             DBMS_OUTPUT.PUT_LINE('NO patient found with ID: ' || p_patient_id);
 10     ELSE
 11             COMMIT;
 12             DBMS_OUTPUT.PUT_LINE('Patient record deleted successfully.');
 13     END IF;
 14  EXCEPTION
 15     WHEN OTHERS THEN
 16          ROLLBACK;
 17          DBMS_OUTPUT.PUT_LINE('Error deleting patient record: ' || SQLERRM);
 18  END Delete_Patient_Record;
 SQL> r
Procedure created.
 2  CREATE OR REPLACE FUNCTION GetAllPatientData(
 3      p_patient_id IN NUMBER
 4  ) RETURN SYS_REFCURSOR
 5  AS
 6      patient_cursor SYS_REFCURSOR;
 7  BEGIN
 8      OPEN patient_cursor FOR
 9      SELECT * FROM Patients
 10      WHERE patient_id = p_patient_id;
 11
 12      RETURN patient_cursor;
 13  EXCEPTION
 14      WHEN OTHERS THEN
 15          DBMS_OUTPUT.PUT_LINE('Error retrieving patient data: ' || SQLERRM);
 16          RETURN NULL;
 17  END GetAllPatientData;
 18  /
Procedure created.