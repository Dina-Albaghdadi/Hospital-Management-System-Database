//Sample JDBC Connection Code

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;

public class DBConnection {
    private static final String DB_URL = "jdbc@localhost:1521:oracle";
    private static final String USER = "hospital_db";
    private static final String PASS = "hospital123";
    
    public static Connection getConnection() throws SQLException {
        try {
            // Load the JDBC driver
            Class.forName("oracle.jdbc.driver.OracleDriver");
            
            // Establish connection
            return DriverManager.getConnection(DB_URL, USER, PASS);
        } catch (ClassNotFoundException e) {
            throw new SQLException("Oracle JDBC Driver not found", e);
        }
    }
}

//Sample Patient Insertion Code

import java.sql.CallableStatement;
import java.sql.Connection;
import java.sql.SQLException;
import java.sql.Types;
import java.text.SimpleDateFormat;
import java.util.Date;

public class PatientDAO {
    public void insertPatient(String firstName, String lastName, Date dob, 
                            String gender, String phone, String address) {
        String sql = "{call Insert_To_Patients(?, ?, ?, ?, ?, ?)}";
        
        try (Connection conn = DBConnection.getConnection();
             CallableStatement stmt = conn.prepareCall(sql)) {
            
            // Convert java.util.Date to java.sql.Date
            java.sql.Date sqlDob = new java.sql.Date(dob.getTime());
            
            stmt.setString(1, firstName);
            stmt.setString(2, lastName);
            stmt.setDate(3, sqlDob);
            stmt.setString(4, gender);
            stmt.setString(5, phone);
            stmt.setString(6, address);
            
            stmt.execute();
            System.out.println("Patient inserted successfully");
        } catch (SQLException e) {
            System.err.println("Error inserting patient: " + e.getMessage());
        }
    }
}
